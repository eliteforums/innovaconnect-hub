# ══════════════════════════════════════════════════════════════════════════════
# InnovaHack 2026 — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env (or .env.local) and fill in your actual values.
# NEVER commit files containing real keys to version control.
# After editing, restart the dev server: npm run dev
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# SUPABASE — Core (Required)
# Find in: Supabase Dashboard → Project Settings → API
# ──────────────────────────────────────────────────────────────

# Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon / Public key (safe for browser — DO NOT use service_role key here)
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ──────────────────────────────────────────────────────────────
# SUPABASE — Edge Functions (Server-side only)
# These are used by Edge Functions, NOT exposed in the frontend.
# Set them in: Supabase Dashboard → Edge Functions → Secrets
# ──────────────────────────────────────────────────────────────

# Service Role Key — bypasses RLS, used for credential generation
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# RESEND — Email Delivery (Server-side only)
# Set in: Supabase Dashboard → Edge Functions → Secrets
# Get your API key at: https://resend.com/api-keys
# ──────────────────────────────────────────────────────────────

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# VERCEL — Analytics (Optional, auto-injected by Vercel)
# ──────────────────────────────────────────────────────────────

# VITE_VERCEL_ANALYTICS_ID=auto-injected

# ══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
#
# Frontend (Vercel):
#   - VITE_SUPABASE_URL
#   - VITE_SUPABASE_ANON_KEY
#
# Edge Functions (Supabase Secrets):
#   - SUPABASE_URL (auto-available)
#   - SUPABASE_SERVICE_ROLE_KEY (auto-available)
#   - RESEND_API_KEY (must add manually)
#
# ══════════════════════════════════════════════════════════════════════════════
